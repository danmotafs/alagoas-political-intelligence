def classificar_prioridade(rank: int) -> str:
    if rank <= 10:
        return "Muito alta"
    if rank <= 20:
        return "Alta"
    if rank <= 40:
        return "Média"
    return "Monitoramento"


def classificar_status(rank: int) -> str:
    if rank <= 20:
        return "Priorizar curadoria"
    if rank <= 40:
        return "Avaliar após top 20"
    return "Monitorar"


def justificar_prioridade(rank: int, eleitorado: int, votos_vereadores: int) -> str:
    if rank <= 10:
        return (
            "Município no núcleo prioritário inicial pela combinação de peso eleitoral, "
            "força municipal e potencial de articulação política."
        )

    if rank <= 20:
        return (
            "Município estratégico para expansão inicial da candidatura à reeleição, "
            "com necessidade de curadoria de lideranças locais."
        )

    if rank <= 40:
        return (
            "Município relevante para segunda onda de visitas e validação de aderência política."
        )

    return (
        "Município mantido em monitoramento para atualização posterior conforme novas alianças."
    )


def calcular_base_gabi(root: Path) -> pd.DataFrame:
    base = preparar_base_municipios(root)
    ranking = preparar_ranking(root)
    politica = preparar_politica_municipal(root)
    vereadores = preparar_vereadores_municipal(root)

    df = base.merge(ranking, on="municipio_key", how="left")
    df = df.merge(politica, on="municipio_key", how="left")
    df = df.merge(vereadores, on="municipio_key", how="left")

    colunas_num = [
        "ranking_base_davi",
        "indice_estrategico_base_davi",
        "votos_prefeito_2024",
        "margem_vitoria_prefeito",
        "vereadores_mapeados",
        "votos_vereadores_total",
    ]

    for coluna in colunas_num:
        if coluna not in df.columns:
            df[coluna] = 0
        df[coluna] = converter_numero(df[coluna])

    for coluna in ["prefeito_2024", "partido_prefeito_2024"]:
        if coluna not in df.columns:
            df[coluna] = ""
        df[coluna] = df[coluna].fillna("").astype(str)

    df["score_eleitorado"] = normalizar_0_100(df["eleitorado"])
    df["score_vereadores"] = normalizar_0_100(df["votos_vereadores_total"])

    if df["indice_estrategico_base_davi"].sum() > 0:
        df["score_base_davi"] = normalizar_0_100(df["indice_estrategico_base_davi"])
    else:
        df["score_base_davi"] = df["score_eleitorado"]

    df["score_gabi_preliminar"] = (
        df["score_base_davi"] * 0.50
        + df["score_eleitorado"] * 0.35
        + df["score_vereadores"] * 0.15
    )

    df = df.sort_values(
        by=["score_gabi_preliminar", "eleitorado"],
        ascending=[False, False],
    ).reset_index(drop=True)

    df["ranking_gabi_preliminar"] = range(1, len(df) + 1)
    df["prioridade_visita_gabi"] = df["ranking_gabi_preliminar"].apply(classificar_prioridade)
    df["status_articulacao_gabi"] = df["ranking_gabi_preliminar"].apply(classificar_status)

    df["relacao_gabi"] = "A CURAR"
    df["aderencia_gabi"] = "A CURAR"
    df["grupo_politico_gabi"] = "A CURAR"
    df["observacao_curadoria_gabi"] = ""

    df["justificativa_prioridade_gabi"] = df.apply(
        lambda row: justificar_prioridade(
            int(row["ranking_gabi_preliminar"]),
            int(row["eleitorado"]),
            int(row["votos_vereadores_total"]),
        ),
        axis=1,
    )

    peso = df["score_gabi_preliminar"].clip(lower=1)

    fator_prioridade = df["ranking_gabi_preliminar"].apply(
        lambda rank: 1.0 if rank <= 40 else 0.25
    )

    pesos_ajustados = peso * fator_prioridade
    total_pesos = pesos_ajustados.sum()

    if total_pesos > 0:
        df["meta_votos_referencia_gabi"] = (
            (pesos_ajustados / total_pesos) * META_TRABALHO_GABI
        ).round().astype(int)
    else:
        df["meta_votos_referencia_gabi"] = 0

    diferenca = META_TRABALHO_GABI - int(df["meta_votos_referencia_gabi"].sum())

    if len(df) > 0 and diferenca != 0:
        df.loc[0, "meta_votos_referencia_gabi"] += diferenca

    df["potencial_transferencia_vereadores_5pct"] = (
        df["votos_vereadores_total"] * 0.05
    ).round().astype(int)

    df["potencial_transferencia_vereadores_10pct"] = (
        df["votos_vereadores_total"] * 0.10
    ).round().astype(int)

    df["potencial_transferencia_vereadores_15pct"] = (
        df["votos_vereadores_total"] * 0.15
    ).round().astype(int)

    ordem_colunas = [
        "ranking_gabi_preliminar",
        "municipio",
        "eleitorado",
        "populacao",
        "score_gabi_preliminar",
        "prioridade_visita_gabi",
        "status_articulacao_gabi",
        "meta_votos_referencia_gabi",
        "ranking_base_davi",
        "indice_estrategico_base_davi",
        "prefeito_2024",
        "partido_prefeito_2024",
        "votos_prefeito_2024",
        "margem_vitoria_prefeito",
        "vereadores_mapeados",
        "votos_vereadores_total",
        "potencial_transferencia_vereadores_5pct",
        "potencial_transferencia_vereadores_10pct",
        "potencial_transferencia_vereadores_15pct",
        "relacao_gabi",
        "aderencia_gabi",
        "grupo_politico_gabi",
        "observacao_curadoria_gabi",
        "justificativa_prioridade_gabi",
        "municipio_key",
    ]

    for coluna in ordem_colunas:
        if coluna not in df.columns:
            df[coluna] = ""

    return df[ordem_colunas]


