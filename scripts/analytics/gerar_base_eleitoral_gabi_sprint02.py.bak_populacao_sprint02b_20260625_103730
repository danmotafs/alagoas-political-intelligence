def salvar_resultados(root: Path, df: pd.DataFrame) -> None:
    final_dir = root / "data" / "final" / "parceiros" / "gabi-goncalves"
    reference_dir = root / "data" / "reference" / "parceiros" / "gabi-goncalves"
    dashboard_dir = root / "data" / "dashboard" / "parceiros" / "gabi-goncalves"
    docs_dir = root / "docs"

    final_dir.mkdir(parents=True, exist_ok=True)
    reference_dir.mkdir(parents=True, exist_ok=True)
    dashboard_dir.mkdir(parents=True, exist_ok=True)
    docs_dir.mkdir(parents=True, exist_ok=True)

    base_csv = final_dir / "base_eleitoral_gabi_v1.csv"
    base_xlsx = final_dir / "base_eleitoral_gabi_v1.xlsx"
    curadoria_csv = reference_dir / "campos_curadoria_gabi_v1.csv"
    dashboard_json = dashboard_dir / "base_dashboard_gabi_v1.json"
    meta_json = dashboard_dir / "meta_eleitoral_gabi_estadual_2026.json"
    cruzamento_json = dashboard_dir / "cruzamento_davi_gabi_v1.json"
    briefing_md = docs_dir / "briefing_gabi_sprint02.md"

    df.to_csv(base_csv, index=False, encoding="utf-8-sig")
    print(f"[OK] CSV salvo: {base_csv}")

    try:
        df.to_excel(base_xlsx, index=False)
        print(f"[OK] XLSX salvo: {base_xlsx}")
    except Exception as erro:
        print(f"[AVISO] Não foi possível salvar XLSX. CSV foi gerado normalmente. Erro: {erro}")

    curadoria = gerar_curadoria(df)
    curadoria.to_csv(curadoria_csv, index=False, encoding="utf-8-sig")
    print(f"[OK] Planilha de curadoria salva: {curadoria_csv}")

    dashboard_json.write_text(
        json.dumps(gerar_base_dashboard(df), ensure_ascii=False, indent=2),
        encoding="utf-8",
    )
    print(f"[OK] JSON dashboard salvo: {dashboard_json}")

    meta_json.write_text(
        json.dumps(gerar_meta_json(df), ensure_ascii=False, indent=2),
        encoding="utf-8",
    )
    print(f"[OK] JSON meta salvo: {meta_json}")

    cruzamento_json.write_text(
        json.dumps(gerar_cruzamento_json(df), ensure_ascii=False, indent=2),
        encoding="utf-8",
    )
    print(f"[OK] JSON cruzamento salvo: {cruzamento_json}")

    briefing_md.write_text(gerar_briefing_sprint02(), encoding="utf-8")
    print(f"[OK] Briefing salvo: {briefing_md}")


